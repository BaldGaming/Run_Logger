<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISTANCE"
            android:id="@+id/my_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RUN LOGGER"
            android:textColor="@android:color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp" />

        <View
            android:id="@+id/title_underline"
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:background="@color/accent_green"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/my_title"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/upload_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="SELECT PHOTO"
            android:backgroundTint="@color/accent_green"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/title_underline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/stats_grid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/upload_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                android:background="@drawable/tile_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView android:text="DISTANCE" android:textColor="@color/text_secondary" android:textSize="10sp" android:gravity="center"/>
                <TextView android:id="@+id/stat_distance" android:text="— KM" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnWeight="1"
                android:background="@drawable/tile_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView android:text="TIME" android:textColor="@color/text_secondary" android:textSize="10sp" android:gravity="center"/>
                <TextView android:id="@+id/stat_time" android:text="—" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" android:gravity="center"/>
            </LinearLayout>
        </androidx.gridlayout.widget.GridLayout>

        <EditText
            android:id="@+id/notion_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Scanned value review..."
            android:textColor="@android:color/white"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/accent_green"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/stats_grid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/feedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready to log"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/notion_input"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>